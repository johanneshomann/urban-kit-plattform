# Database
DATABASE_URI=mongodb://localhost:27017/urban_kit

# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MEDIA=media
S3_BUCKET_FILES=project-files

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@urbankit.de

# Domains
NEXT_PUBLIC_PUBLIC_DOMAIN=urbankit.de
NEXT_PUBLIC_APP_DOMAIN=app.urbankit.de
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# AI (pick one or more)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Hocuspocus (realtime sidecar for Board)
HOCUSPOCUS_URL=ws://localhost:1234
HOCUSPOCUS_SECRET=change-me-hocuspocus-secret
# Browser-facing WS URL for the board client (public; use wss:// in production)
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:1234
# Where the sidecar reaches Payload for auth + persistence (compose: http://web:3000)
PAYLOAD_INTERNAL_URL=http://localhost:3000
